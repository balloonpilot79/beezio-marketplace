# ========================================
# NETLIFY ENVIRONMENT VARIABLES (Server-side)
# ========================================
# Set these in Netlify UI: Site settings → Environment variables
# These are read by Netlify Functions (cj-quote-shipping, cj-fulfill-order, etc.)
# DO NOT prefix with VITE_ for server-side secrets

CJ_API_KEY=your-cj-api-key-here
SUPABASE_URL=https://yemgssttxhkgrivuodbz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========================================
# PAYPAL (Server-side)
# ========================================
# Required for PayPal Orders + Webhooks + optional Payouts.
# PAYPAL_ENV: sandbox | live
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Optional but recommended: dedicated OAuth app/settings for "Connect PayPal" payout linking.
# If omitted, connect flow falls back to PAYPAL_CLIENT_ID / PAYPAL_CLIENT_SECRET.
PAYPAL_CONNECT_CLIENT_ID=your-paypal-connect-client-id
PAYPAL_CONNECT_CLIENT_SECRET=your-paypal-connect-client-secret
# Must exactly match the callback URL configured in the PayPal app:
# e.g. https://beezio.co/paypal/connect/callback
PAYPAL_CONNECT_REDIRECT_URI=https://beezio.co/paypal/connect/callback
# Default scopes are fine for most setups.
# PAYPAL_CONNECT_SCOPES=openid email profile

# Required for webhook signature verification (PayPal Webhook ID)
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Optional overrides
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# Fee + pricing controls used by Netlify Functions
PAYPAL_FEE_PERCENT=0.0349
PAYPAL_FEE_FIXED=0.49

# Extra $ buffer added on top of estimated PayPal fees (order-level)
PAYPAL_PAYOUT_BUFFER=0.65
BEEZIO_RATE=0.15

# Payouts controls
PAYOUT_HOLD_DAYS=14
PAYOUTS_ENABLED=false
PAYOUTS_MINIMUM=25

# Backward-compatible aliases (older configs)
# BEEZIO_PAYOUT_HOLD_DAYS=14
# PAYPAL_MIN_PAYOUT=25
# PAYPAL_PAYOUTS_API_ENABLED=false

# Optional (defaults are fine):
# CJ_API_BASE_URL=https://developers.cjdropshipping.com/api2.0/v1/

# ========================================
# CJ BULK IMPORT DEFAULTS (Server-side)
# ========================================
# Optional fallback category id (UUID from categories table)
# DEFAULT_BEEZIO_CATEGORY_ID=
# Default behavior for missing inventory: deny | continue
DEFAULT_UNKNOWN_INVENTORY_POLICY=deny


# ========================================
# LOCAL .env FILE (Development)
# ========================================
# Copy this section to your local .env file (DO NOT COMMIT .env)
# These VITE_ prefixed vars are embedded in the frontend build

VITE_SUPABASE_URL=https://yemgssttxhkgrivuodbz.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# For running Netlify Functions locally (do NOT expose in browser builds)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# PayPal JS SDK (client-side)
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id



# Only needed if you call CJ directly from browser (currently not used):
# VITE_CJ_API_KEY=your-cj-api-key-here

# Optional dev tools:
# VITE_GPT_PROXY_ENDPOINT=/.netlify/functions/gpt-proxy
# VITE_CJ_API_BASE_URL=https://developers.cjdropshipping.com/api2.0/v1/


# ========================================
# SECURITY NOTES
# ========================================
# 1. NEVER commit .env or paste secrets in chat/github issues
# 2. Rotate keys immediately if exposed (you just did - rotate them now!)
# 3. Service role key = full database access - Netlify server-side ONLY
# 4. Anon key = safe for browser/frontend
# 5. After setting Netlify env vars, trigger a new deploy to pick them up


# ========================================
# QUICK SETUP CHECKLIST
# ========================================
# [ ] 1. Rotate CJ API key (CJ portal)
# [ ] 2. Rotate Supabase service_role key (Supabase → Settings → API)
# [ ] 3. Set CJ_API_KEY in Netlify env vars
# [ ] 4. Set SUPABASE_URL in Netlify env vars
# [ ] 5. Set SUPABASE_SERVICE_ROLE_KEY in Netlify env vars
# [ ] 6. Set PAYPAL_ENV, PAYPAL_CLIENT_ID, PAYPAL_CLIENT_SECRET in Netlify env vars
# [ ] 7. Set PAYPAL_CONNECT_CLIENT_ID, PAYPAL_CONNECT_CLIENT_SECRET, PAYPAL_CONNECT_REDIRECT_URI
# [ ] 8. Set PAYPAL_WEBHOOK_ID in Netlify env vars
# [ ] 9. Set VITE_PAYPAL_CLIENT_ID in Netlify env vars
# [ ] 10. Trigger Netlify redeploy
# [ ] 11. Test PayPal checkout in sandbox
