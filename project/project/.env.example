# Client (safe to expose)
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="<SUPABASE_ANON_JWT>"
VITE_GPT_PROXY_ENDPOINT="/.netlify/functions/gpt-proxy"

# Server-only (Netlify Functions environment variables)
# IMPORTANT: do NOT prefix these with VITE_ (that would expose them to the browser build)
SUPABASE_URL="https://<your-project-ref>.supabase.co"
# Optional for Netlify Functions (they will fall back to VITE_SUPABASE_ANON_KEY if present)
SUPABASE_ANON_KEY="<SUPABASE_ANON_JWT>"
SUPABASE_SERVICE_ROLE_KEY="<SUPABASE_SERVICE_ROLE_JWT>"

# Email (reply-to-customer without exposing seller email)
SENDGRID_API_KEY="SG.xxxxx"
BEEZIO_FROM_EMAIL="support@beezio.co"
BEEZIO_FROM_NAME="Beezio"
CJ_API_KEY="CJxxxxxx@api@xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CJ_API_BASE_URL="https://developers.cjdropshipping.com/api2.0/v1/"

# Server-only (Supabase Edge Functions environment variables)
SUPABASE_URL="https://<your-project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<SUPABASE_SERVICE_ROLE_JWT>"
SITE_URL="https://beezio-marketplace.netlify.app"
